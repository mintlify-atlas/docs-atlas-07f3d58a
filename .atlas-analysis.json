  "keyFeatures": [
    "Role-based access control (admin and user roles)",
    "Room reservation system with multi-slot time booking",
    "Reservation approval workflow (pending/approved/rejected)",
    "Material assignment to reservations",
    "Custom MVC architecture with PHP router",
    "Session-based authentication",
    "Conflict detection for overlapping reservations",
    "Dashboard views tailored by user role"
